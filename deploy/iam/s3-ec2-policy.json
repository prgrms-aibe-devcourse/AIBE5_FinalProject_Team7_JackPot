{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WhiskeyNoteImagesObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::team7-whiskeynote-images/*"
    },
    {
      "Sid": "WhiskeyNoteImagesListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::team7-whiskeynote-images"
    }
  ]
}
