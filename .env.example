# cp .env.example .env 후 값 설정 (.env 는 git 제외)
#
# 로컬 docker compose (mysql 서비스):
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/whiskeynote?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=localroot
#
# EC2 + RDS 예시 (mysql 서비스 제거 후):
# SPRING_DATASOURCE_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/whiskeynote?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
# SPRING_DATASOURCE_USERNAME=admin
# SPRING_DATASOURCE_PASSWORD=<RDS_PASSWORD>
#
# S3 (이미지 업로드 — EC2 .env 필수, Phase 2)
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=team7-whiskeynote-images

# OAuth (AUTH-03) — EC2 .env에 실제 값 추가 필요
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_REDIRECT_URI=
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_REDIRECT_URI=
